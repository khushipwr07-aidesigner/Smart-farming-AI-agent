    {
      "parameters": {
        "description": "Recommend crops based on:\n\nsoil type\nseason\nrainfall\ntemperature\nwater availability",
        "jsCode": "const soil = ($input.first().json.soil_type || \"\").toLowerCase();\nconst season = ($input.first().json.season || \"\").toLowerCase();\nconst rainfall = Number($input.first().json.rainfall || 0);\nconst temperature = Number($input.first().json.temperature || 0);\nconst water = ($input.first().json.water_availability || \"\").toLowerCase();\n\nlet crops = [];\n\nif (soil.includes(\"black\") && season === \"kharif\") {\n    crops.push({\n        crop: \"Cotton\",\n        reason: \"Black soil is ideal for cotton.\"\n    });\n\n    crops.push({\n        crop: \"Soybean\",\n        reason: \"Soybean grows well in black soil.\"\n    });\n}\n\nif ((soil.includes(\"clay\") || soil.includes(\"alluvial\")) && rainfall > 120) {\n    crops.push({\n        crop: \"Rice\",\n        reason: \"High rainfall supports rice cultivation.\"\n    });\n}\n\nif (season === \"rabi\" && temperature >= 15 && temperature <= 25) {\n    crops.push({\n        crop: \"Wheat\",\n        reason: \"Cool temperatures are ideal for wheat.\"\n    });\n}\n\nif (rainfall >= 50 && rainfall <= 100 && temperature >= 20 && temperature <= 30) {\n    crops.push({\n        crop: \"Maize\",\n        reason: \"Moderate rainfall and temperature suit maize.\"\n    });\n}\n\nif (crops.length === 0) {\n    crops.push({\n        crop: \"No recommendation\",\n        reason: \"Please provide complete farming information.\"\n    });\n}\n\nreturn [{ json: { recommended_crops: crops } }];"
      },
